    {
      "parameters": {
        "jsCode": "const raw = items[0].json.choices[0].message.content;\nconst summaries = JSON.parse(raw.replace(/```json|```/g, '').trim());\nconst stories = $('Prompt to give to groq').first().json.stories;\n\nreturn stories.map((story, i) => ({\n  json: {\n    title: story.title,\n    url: story.url || null,\n    score: story.score,\n    summary: summaries[i]?.summary || ''\n  }\n}));"
      },
