    {
      "parameters": {
        "jsCode": "const storyList = items.map((item, i) => \n  `${i+1}. ${item.json.title} (Score: ${item.json.score})`\n).join(' | ');\n\nconst prompt = `Here are today top Hacker News stories: ${storyList}. For each story write one sentence explaining what it is about. Return ONLY a JSON array like this: [{\"index\": 1, \"summary\": \"one sentence here\"}]. No other text outside the array.`;\n\nreturn [{ \n  json: { \n    prompt: prompt,\n    stories: items.map(i => i.json)\n  } \n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
